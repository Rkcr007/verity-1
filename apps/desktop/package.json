{
  "name": "@verity/desktop",
  "version": "0.1.0",
  "productName": "Verity",
  "private": true,
  "description": "Verity desktop shell — Electron main process, preload bridge, IPC infrastructure.",
  "main": "out/main/main.cjs",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "dev": "electron-rebuild -f -w better-sqlite3 && node ./scripts/dev.mjs",
    "start": "electron .",
    "test": "npm rebuild better-sqlite3 --silent && node --import tsx --test 'src/**/*.test.ts'",
    "test:electron-db": "electron-rebuild -f -w better-sqlite3 && pnpm exec electron ./scripts/test-db.cjs",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "clean": "rimraf out .turbo"
  },
  "dependencies": {
    "@verity/adapter-contract": "workspace:*",
    "@verity/adapter-playwright-java": "workspace:*",
    "@verity/adapter-playwright-typescript": "workspace:*",
    "@verity/ai-orchestration": "workspace:*",
    "@verity/core": "workspace:*",
    "@verity/execution-engine": "workspace:*",
    "@verity/local-persistence": "workspace:*",
    "@verity/repository-intelligence": "workspace:*",
    "@verity/semantic-model": "workspace:*",
    "@verity/toolchain": "workspace:*",
    "better-sqlite3": "^11.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^20.14.10",
    "electron": "^31.3.1",
    "tsx": "^4.19.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4"
  }
}
